{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents an authenticated user within the system",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Auth UID" },
        "email": { "type": "string", "description": "Email address" },
        "displayName": { "type": "string", "description": "Display name of the user" },
        "photoURL": { "type": "string", "description": "Profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email"]
    },
    "Project": {
      "title": "Project",
      "description": "A UI design project configured for visual comparative audits",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Project identifier" },
        "name": { "type": "string", "description": "Name of the project" },
        "clientName": { "type": "string", "description": "Client company name" },
        "websiteUrl": { "type": "string", "description": "Live production or staging URL" },
        "figmaUrl": { "type": "string", "description": "Optional Figma design file/frame URL" },
        "environment": { "type": "string", "enum": ["localhost", "staging", "production", "wordpress", "static"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string", "description": "Owner userId" }
      },
      "required": ["id", "name", "clientName", "websiteUrl", "environment", "userId", "createdAt"]
    },
    "AnalysisRun": {
      "title": "AnalysisRun",
      "description": "An automated visual comparative QA snapshot report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed", "failed"] },
        "startedAt": { "type": "string", "format": "date-time" },
        "completedAt": { "type": "string", "format": "date-time" },
        "designImage": { "type": "string", "description": "Mockup reference image" },
        "siteImage": { "type": "string", "description": "Website staging comparison image" },
        "score": { "type": "number", "description": "Similarity alignment index out of 100" },
        "issues": { "type": "array", "description": "List of layout discrepancies" },
        "userId": { "type": "string", "description": "Owner identifier" }
      },
      "required": ["id", "projectId", "status", "startedAt", "designImage", "siteImage", "score", "issues", "userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile store"
    },
    "projects/{projectId}": {
      "schema": "Project",
      "description": "Registered QA project workspaces"
    },
    "historyRuns/{runId}": {
      "schema": "AnalysisRun",
      "description": "Comparatives historical audit logs"
    }
  }
}
